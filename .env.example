# OpenTron PostgreSQL Environment Configuration
# Save this as .env in the project root or set these variables in your shell

# ==========================================
# PostgreSQL Connection
# ==========================================
POSTGRES_URL=jdbc:postgresql://localhost:5432/opentron
POSTGRES_USER=opentron
POSTGRES_PASSWORD=opentron_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opentron

# ==========================================
# Ollama/Engine Configuration
# ==========================================
ENGINE_HOST=http://localhost:11434
ENGINE_TYPE=auto
ENGINE_APIKEY=

# ==========================================
# Application Settings
# ==========================================
APP_PORT=8000
APP_ENV=development

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=DEBUG
LOG_FILE=logs/opentron-backend.log

# ==========================================
# Docker Container Names (if using Docker)
# ==========================================
POSTGRES_CONTAINER=opentron-postgres
OLLAMA_CONTAINER=opentron-ollama
BACKEND_CONTAINER=opentron-backend
