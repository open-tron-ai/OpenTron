{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenTron",
  "version": "1.0.1",
  "identifier": "com.opentron.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "OpenTron",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "resources": [
      "sidecar/backend.jar"
    ],
    "externalBin": [
      "sidecar/opentron-backend-x86_64-pc-windows-msvc.exe",
      "sidecar/opentron-backend-x86_64-apple-darwin",
      "sidecar/opentron-backend-aarch64-apple-darwin",
      "sidecar/opentron-backend-x86_64-unknown-linux-gnu"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Multi-agent AI orchestration with real-time monitoring",
    "longDescription": "OpenTron: Production-ready AI agents with 14+ connector integrations, real-time energy monitoring, trace debugging, and PostgreSQL support.",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["opentron"]
      }
    }
  }
}
